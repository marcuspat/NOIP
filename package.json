{
  "name": "noip",
  "version": "1.0.0",
  "description": "NetOps Intelligence Platform (NOIP)",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:integration": "jest --testPathPatterns=integration",
    "test:unit": "jest --testPathPatterns=unit",
    "test:contract": "jest --config=jest.contract.config.cjs --runInBand --testTimeout=30000",
    "build": "tsc",
    "lint": "eslint src/**/*.ts tests/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts tests/**/*.ts",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "format:check": "prettier --check src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "playwright": "playwright test",
    "dev": "ts-node src/app.ts",
    "start": "node dist/app.js",
    "prebuild": "npm run lint:check && npm run typecheck",
    "pretest": "npm run lint:check"
  },
  "keywords": [
    "infrastructure-intelligence",
    "netops",
    "kubernetes",
    "security-scanning",
    "ai-integration",
    "enterprise-platform",
    "devops-tool",
    "infrastructure-monitoring",
    "dashboard",
    "typescript",
    "nodejs",
    "docker",
    "mongodb",
    "redis",
    "api",
    "microservices",
    "claude-ai",
    "anthropic",
    "automation",
    "compliance",
    "vulnerability-scanning",
    "cloud-native",
    "observability",
    "security-operations"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^16.2.6",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "winston": "^3.18.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@kubernetes/client-node": "^0.21.0",
    "@types/argon2": "^0.14.1",
    "@types/mongoose": "^5.11.96",
    "@types/nodemailer": "^7.0.3",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.3.0",
    "ioredis": "^5.8.2",
    "jose": "^6.1.0",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.0.0",
    "redis": "^5.9.0",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0"
  }
}
